// Economical first-pass resources for ~60x tumor / 30x normal short-read WGS.
// Keep only the small reusable utility class; use per-process overrides for callers.
// Retry broadly on transient scheduler/container/filesystem-style failures.
process {
  cpus = 1
  memory = 4.GB
  time = 2.h
  errorStrategy = { (task.exitStatus in [104]) || (task.exitStatus in 130..145) ? 'retry' : 'finish' }
  maxRetries = 1

  withLabel: utility {
    cpus = 1
    memory = 4.GB
    time = 2.h
    maxRetries = 2
  }

  withName: PREP_REFERENCE {
    cpus = { Math.min(2 * task.attempt, 4) }
    memory = { "${8 * task.attempt} GB" }
    time = { "${6 * task.attempt} h" }
    maxRetries = 2
  }

  withName: MERGE {
    cpus = { 2 * task.attempt }
    memory = { "${8 * task.attempt} GB" }
    time = { "${4 * task.attempt} h" }
    maxRetries = 2
  }

  withName: TUMOUR_CONSENSUS_VCF {
    cpus = { 2 * task.attempt }
    memory = { "${8 * task.attempt} GB" }
    time = { "${4 * task.attempt} h" }
    maxRetries = 2
  }

  withName: MANTA {
    cpus = { Math.min(4 * task.attempt, 8) }
    memory = { "${8 * task.attempt} GB" }
    time = { "${6 * task.attempt} h" }
    maxRetries = 2
  }

  withName: LUMPY {
    cpus = { Math.min(4 * task.attempt, 8) }
    memory = { "${12 * task.attempt} GB" }
    time = { "${12 * task.attempt} h" }
    maxRetries = 2
  }

  withName: DELLY {
    queue = "${PW_ONDEMAND_JOB_QUEUE}"
    cpus = { Math.min(4 * task.attempt, 8) }
    memory = { "${48 * task.attempt} GB" }
    time = { "${24 * task.attempt} h" }
    maxRetries = 2
  }

  withName: SVABA {
    queue = "${PW_ONDEMAND_JOB_QUEUE}"
    cpus = { Math.min(8 * task.attempt, 16) }
    memory = { "${16 * task.attempt} GB" }
    time = { "${24 * task.attempt} h" }
    maxRetries = 2
  }

  withName: GRIDSS {
    queue = "${PW_ONDEMAND_JOB_QUEUE}"
    // Keep GRIDSS task memory flat so the 75% heap formula stays at 30g and
    // avoids retry-time JVM heaps in the upstream-discouraged 32-48 GB range.
    cpus = { Math.min(8 * task.attempt, 16) }
    memory = 40.GB
    time = { "${24 * task.attempt} h" }
    maxRetries = 2
  }
}
