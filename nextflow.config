// NASA.SV

params {
  csv = null
  publishDir = 'results'
  genome_build = 'hg38'

  genome_build_aliases = [
    'hg38'  : 'hg38',
    'grch38': 'hg38',
    '38'    : 'hg38',
    'hg19'  : 'hg19',
    'grch37': 'hg19',
    'b37'   : 'hg19',
    'hs37d5': 'hg19',
    '37'    : 'hg19',
    'other' : 'other',
  ]

  reference_defaults = [
    'hg38': [
      reference_fasta      : 'https://ftp.1000genomes.ebi.ac.uk/vol1/ftp/technical/reference/GRCh38_reference_genome/GRCh38_full_analysis_set_plus_decoy_hla.fa',
      gridss_blacklist     : 'https://www.encodeproject.org/files/ENCFF356LFX/@@download/ENCFF356LFX.bed.gz',
      gridss_resource_bundle: 'https://storage.googleapis.com/hmf-public/HMFtools-Resources/pipeline/oncoanalyser/2.3/38/hmf_pipeline_resources.38_v2.3.0--2.tar.gz',
    ],
    'hg19': [
      reference_fasta      : 'https://ftp.1000genomes.ebi.ac.uk/vol1/ftp/technical/reference/phase2_reference_assembly_sequence/hs37d5.fa.gz',
      gridss_blacklist     : 'https://www.encodeproject.org/files/ENCFF001TDO/@@download/ENCFF001TDO.bed.gz',
      gridss_resource_bundle: 'https://storage.googleapis.com/hmf-public/HMFtools-Resources/pipeline/oncoanalyser/2.3/37/hmf_pipeline_resources.37_v2.3.0--2.tar.gz',
    ],
  ]

  default_gridss_properties = 'https://raw.githubusercontent.com/PapenfussLab/gridss/825bc8e1bb092e9bb2ccb0c1c51dc6e7e1a922dd/src/main/resources/gridss.properties'

  reference_fasta = null
  reference_index = null
  gridss_blacklist = null
  gridss_properties = null
  gridss_sv_pon = null
  gridss_sgl_pon = null
  gridss_resource_bundle = null
}

profiles {

  singularity {
    singularity.enabled = true
    singularity.autoMounts = true
  }

  docker {
    docker.enabled = true
    docker.autoMounts = true
  }

  test {
    params.csv = "${projectDir}/test.csv"
    params.publishDir = "${projectDir}/test/result/"
  }

  bundle_paths {
    params.genome_build = 'hg38'
    params.reference_fasta = "${projectDir}/data/ref1000g/GRCh38_full_analysis_set_plus_decoy_hla.fa"
    params.reference_index = "${projectDir}/data/ref1000g/GRCh38_full_analysis_set_plus_decoy_hla.fa.fai"
    params.gridss_blacklist = "${projectDir}/data/gridsspl/gpl_ref_gatk_38/dbs/gridss/ENCFF001TDO.bed"
    params.gridss_properties = "${projectDir}/data/gridsspl/gpl_ref_gatk_38/dbs/gridss/gridss.properties"
  }

}
includeConfig 'conf/resources.config'
